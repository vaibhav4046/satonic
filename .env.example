# All keys OPTIONAL except DATABASE_URL. Satonic falls through LLM providers automatically.
# Sign-up links: docs/self-hosting.md

# === Database (REQUIRED — Neon Postgres free tier) ===
# Get free at https://console.neon.tech (no card)
# Format: postgres://user:pass@ep-xxx.region.neon.tech/dbname?sslmode=require
DATABASE_URL=

# === LLM providers (fallback order) ===
# NVIDIA NIM — https://build.nvidia.com (free tier, primary)
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Groq — https://console.groq.com (free tier)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras — https://cloud.cerebras.ai (free tier)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# OpenRouter — https://openrouter.ai (free models available)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# === Optional data sources ===
# Google Places — https://console.cloud.google.com (free $200/mo credit)
GOOGLE_PLACES_API_KEY=

# YouTube Data API v3 — https://console.cloud.google.com (free 10k units/day)
YOUTUBE_API_KEY=

# === Telemetry (opt-in, off by default) ===
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# === Runtime ===
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Satonic
